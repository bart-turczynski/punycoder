linters: linters_with_defaults(
    # object_usage_linter is off: this package's public surface is Rcpp-exported
    # (the *_cpp shims in R/RcppExports.R are generated glue), and the testthat
    # suite leans on the expect_* DSL plus `:::` reach-ins to internal helpers,
    # all of which the static usage linter misreads as undefined globals. The
    # rest of the default linter set stays on.
    object_usage_linter = NULL
  )
encoding: "UTF-8"
